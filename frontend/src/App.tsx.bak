import React, { useState, useEffect, useRef } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  Search,
  User,
  Play,
  Volume2,
  VolumeX,
  Cpu,
  Send,
  FileText,
  Video,
  Download,
  RefreshCw,
  FileDown,
  Check,
  ChevronRight,
  Plus,
  Trash,
  Activity,
  Terminal,
  ArrowRight,
  Lock,
  Loader2,
  FileCode
} from 'lucide-react';

// ====================================================
// CUSTOM HOOKS
// ====================================================

// Typewriter Hook (Reference 1)
function useTypewriter(words: string[], speed: number = 100, delay: number = 2000) {
  const [text, setText] = useState('');
  const [wordIndex, setWordIndex] = useState(0);
  const [isDeleting, setIsDeleting] = useState(false);
  const [done, setDone] = useState(false);

  useEffect(() => {
    let timer: any;
    const currentWord = words[wordIndex];

    if (isDeleting) {
      setDone(false);
      timer = setTimeout(() => {
        setText(prev => prev.slice(0, -1));
      }, speed / 2);
    } else {
      timer = setTimeout(() => {
        setText(currentWord.slice(0, text.length + 1));
      }, speed);
    }

    if (!isDeleting && text === currentWord) {
      setDone(true);
      timer = setTimeout(() => setIsDeleting(true), delay);
    } else if (isDeleting && text === '') {
      setIsDeleting(false);
      setWordIndex(prev => (prev + 1) % words.length);
    }

    return () => clearTimeout(timer);
  }, [text, isDeleting, wordIndex, words, speed, delay]);

  return { text, done };
}

// Backend API URL configuration
const API_BASE = 'http://localhost:5000/api';

const logoList = [
  { name: 'Procure', url: 'https://svgl.app/library/procure.svg', gradient: 'linear-gradient(135deg, #0052FF, #00D4FF)' },
  { name: 'Shopify', url: 'https://svgl.app/library/shopify.svg', gradient: 'linear-gradient(135deg, #96BF48, #EAEF20)' },
  { name: 'Blender', url: 'https://svgl.app/library/blender.svg', gradient: 'linear-gradient(135deg, #EA7600, #E8A500)' },
  { name: 'Figma', url: 'https://svgl.app/library/figma.svg', gradient: 'linear-gradient(135deg, #F24E1E, #A259FF)' },
  { name: 'Spotify', url: 'https://svgl.app/library/spotify.svg', gradient: 'linear-gradient(135deg, #FF007A, #FF4B91)' },
  { name: 'Lottielab', url: 'https://svgl.app/library/lottielab.svg', gradient: 'linear-gradient(135deg, #13d080, #b3e61c)' },
  { name: 'Google Cloud', url: 'https://svgl.app/library/google-cloud.svg', gradient: 'linear-gradient(135deg, #4285F4, #00D4FF)' },
  { name: 'Bing', url: 'https://svgl.app/library/bing.svg', gradient: 'linear-gradient(135deg, #008375, #00C4B4)' }
];

export default function App() {
  // Navigation / Workspace States
  const [activeWorkspace, setActiveWorkspace] = useState<string | null>(null);
  const [showCommandPalette, setShowCommandPalette] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');

  // Audio / Video states
  const [isMuted, setIsMuted] = useState(true);
  const videoRef = useRef<HTMLVideoElement>(null);

  // Typewriter state
  const { text: typewriterText, done: typewriterDone } = useTypewriter(
    ['Step Through.', 'Work Smarter.'],
    120,
    2200
  );

  // Interactive Service Selection state (Reference 1 style)
  const [selectedServices, setSelectedServices] = useState<string[]>([]);
  const servicesList = ['AI Web Agent', 'Word Converter', 'PDF Compressor', 'Media Downloader', 'PRD Wizard'];

  // Global diagnostics data state
  const [diagnostics, setDiagnostics] = useState<{
    cpu: string;
    ram: string;
    uptime: string;
    status: string;
    db_status: string;
  } | null>(null);

  // Workspace 1: AI Chat State
  const [chatInput, setChatInput] = useState('');
  const [chatMessages, setChatMessages] = useState<Array<{ sender: 'user' | 'agent'; text: string; sources?: any[] }>>([
    { sender: 'agent', text: 'Halo! Saya adalah ZaysAgent. Ada yang bisa saya bantu hari ini?' }
  ]);
  const [chatLogs, setChatLogs] = useState<Array<{ step: string; detail: string }>>([]);
  const [chatLoading, setChatLoading] = useState(false);

  // Workspace 2: Word Converter State
  const [wordFile, setWordFile] = useState<File | null>(null);
  const [converting, setConverting] = useState(false);
  const [convertedPdfUrl, setConvertedPdfUrl] = useState<string | null>(null);

  // Workspace 3: PDF Compressor State
  const [pdfFile, setPdfFile] = useState<File | null>(null);
  const [compressing, setCompressing] = useState(false);
  const [compressionResult, setCompressionResult] = useState<{
    originalSize: number;
    compressedSize: number;
    pdfUrl: string;
  } | null>(null);

  // Workspace 4: Media Downloader State
  const [mediaUrl, setMediaUrl] = useState('');
  const [mediaFormat, setMediaFormat] = useState('mp4');
  const [mediaQuality, setMediaQuality] = useState('720');
  const [downloadingMedia, setDownloadingMedia] = useState(false);
  const [downloaderResult, setDownloaderResult] = useState<{
    title: string;
    downloadUrl: string;
    status: string;
  } | null>(null);

  // Workspace 5: PRD Wizard State
  const [wizardStep, setWizardStep] = useState(1);
  const [prdData, setPrdData] = useState({
    name: '',
    tagline: '',
    problem: '',
    solution: '',
    features: ['Feature 1', 'Feature 2'],
    techStack: 'React, Go, SQLite'
  });
  const [newFeature, setNewFeature] = useState('');

  // Workspace 6: Settings & Latency State
  const [geminiKey, setGeminiKey] = useState('');
  const [settingsLoading, setSettingsLoading] = useState(false);
  const [pingLatency, setPingLatency] = useState<number | null>(null);

  // ====================================================
  // EFFECT HOOKS
  // ====================================================

  // Desktop Mouse Scrubbing Hook & Mobile Autoplay Hook (Reference 1)
  useEffect(() => {
    const video = videoRef.current;
    if (!video) return;

    let previousX = 0;

    const handleMouseMove = (e: MouseEvent) => {
      // Disable scrubbing if screen width is mobile
      if (window.innerWidth < 1024) return;
      if (!video.duration) return;

      const deltaX = e.clientX - previousX;
      previousX = e.clientX;

      // Adjust target playback time based on mouse delta
      const deltaPercent = deltaX / window.innerWidth;
      const scrubAmount = deltaPercent * 0.8 * video.duration;
      let targetTime = video.currentTime + scrubAmount;

      // Clamp time between 0 and duration
      targetTime = Math.max(0, Math.min(video.duration, targetTime));
      video.currentTime = targetTime;
    };

    window.addEventListener('mousemove', handleMouseMove);

    // Fetch initial diagnostics
    fetchDiagnostics();
    const diagInterval = setInterval(fetchDiagnostics, 60000); // refresh every minute

    // Load settings from DB
    fetchSettings();

    return () => {
      window.removeEventListener('mousemove', handleMouseMove);
      clearInterval(diagInterval);
    };
  }, []);

  // Keyboard shortcut listener for Workspace Command Palette (⌘K / Ctrl+K)
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        setShowCommandPalette(prev => !prev);
      }
    };
    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, []);

  // ====================================================
  // API INTEGRATIONS
  // ====================================================

  const fetchDiagnostics = async () => {
    try {
      const res = await fetch(`${API_BASE}/diagnostics`);
      if (res.ok) {
        const data = await res.json();
        setDiagnostics(data);
      }
    } catch (err) {
      console.warn('Diagnostics endpoint offline');
    }
  };

  const fetchSettings = async () => {
    try {
      const res = await fetch(`${API_BASE}/settings`);
      if (res.ok) {
        const data = await res.json();
        if (data.gemini_api_key) {
          setGeminiKey(data.gemini_api_key);
        }
      }
    } catch (err) {
      console.warn('Backend settings offline');
    }
  };

  const saveSettings = async () => {
    setSettingsLoading(true);
    try {
      const res = await fetch(`${API_BASE}/settings`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ gemini_api_key: geminiKey })
      });
      if (res.ok) {
        alert('API Key berhasil disimpan ke database SQLite!');
      } else {
        alert('Gagal menyimpan API Key');
      }
    } catch (err) {
      alert('Terjadi kesalahan saat menghubungi server.');
    } finally {
      setSettingsLoading(false);
    }
  };

  const handlePing = async () => {
    const start = performance.now();
    try {
      const res = await fetch(`${API_BASE}/diagnostics`);
      if (res.ok) {
        const end = performance.now();
        setPingLatency(Math.round(end - start));
      }
    } catch (err) {
      setPingLatency(null);
    }
  };

  // AI Chat Submit
  const handleChatSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!chatInput.trim()) return;

    const userMsg = chatInput;
    setChatMessages(prev => [...prev, { sender: 'user', text: userMsg }]);
    setChatInput('');
    setChatLoading(true);
    setChatLogs([{ step: 'Inisialisasi', detail: 'Menghubungkan ke server backend...' }]);

    try {
      const res = await fetch(`${API_BASE}/agent-chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: userMsg })
      });

      if (res.ok) {
        const data = await res.json();
        setChatMessages(prev => [...prev, {
          sender: 'agent',
          text: data.answer,
          sources: data.sources
        }]);
        if (data.logs) {
          setChatLogs(data.logs);
        }
      } else {
        setChatMessages(prev => [...prev, { sender: 'agent', text: 'Error: Gagal mendapatkan respon dari server.' }]);
      }
    } catch (err) {
      setChatMessages(prev => [...prev, { sender: 'agent', text: 'Terjadi kesalahan jaringan. Cek apakah backend menyala.' }]);
    } finally {
      setChatLoading(false);
    }
  };

  // Word PDF Conversion Submit
  const handleWordConversion = async () => {
    if (!wordFile) return;
    setConverting(true);
    setConvertedPdfUrl(null);

    const formData = new FormData();
    formData.append('file', wordFile);

    try {
      const res = await fetch(`${API_BASE}/convert-word-pdf`, {
        method: 'POST',
        body: formData
      });

      if (res.ok) {
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        setConvertedPdfUrl(url);

        // Auto download
        const a = document.createElement('a');
        a.href = url;
        a.download = wordFile.name.replace(/\.[^/.]+$/, '') + '.pdf';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      } else {
        alert('Gagal mengonversi file. Cek format berkas Anda.');
      }
    } catch (err) {
      alert('Terjadi kesalahan jaringan.');
    } finally {
      setConverting(false);
    }
  };

  // PDF Compressor Submit
  const handleCompressPdf = async () => {
    if (!pdfFile) return;
    setCompressing(true);
    setCompressionResult(null);

    const formData = new FormData();
    formData.append('file', pdfFile);

    try {
      const res = await fetch(`${API_BASE}/compress-pdf`, {
        method: 'POST',
        body: formData
      });

      if (res.ok) {
        const originalSize = parseInt(res.headers.get('x-original-size') || '0', 10);
        const compressedSize = parseInt(res.headers.get('x-compressed-size') || '0', 10);

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);

        setCompressionResult({
          originalSize,
          compressedSize,
          pdfUrl: url
        });

        // Auto download
        const a = document.createElement('a');
        a.href = url;
        a.download = 'compressed_' + pdfFile.name;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      } else {
        alert('Gagal mengompres PDF.');
      }
    } catch (err) {
      alert('Terjadi kesalahan jaringan.');
    } finally {
      setCompressing(false);
    }
  };

  // Media Downloader Submit
  const handleMediaDownload = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!mediaUrl.trim()) return;

    setDownloadingMedia(true);
    setDownloaderResult(null);

    try {
      const res = await fetch(`${API_BASE}/media-download`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          url: mediaUrl,
          format: mediaFormat,
          quality: mediaQuality
        })
      });

      if (res.ok) {
        const data = await res.json();
        setDownloaderResult({
          title: data.title,
          downloadUrl: data.downloadUrl,
          status: data.status
        });
      } else {
        alert('Gagal mendapatkan tautan download.');
      }
    } catch (err) {
      alert('Koneksi ke server gagal.');
    } finally {
      setDownloadingMedia(false);
    }
  };

  // ====================================================
  // INTERACTIVE BEHAVIORS
  // ====================================================

  const toggleServiceSelection = (service: string) => {
    setSelectedServices(prev =>
      prev.includes(service)
        ? prev.filter(s => s !== service)
        : [...prev, service]
    );
  };

  const openSelectedWorkspaces = () => {
    if (selectedServices.length > 0) {
      // Open the first selected workspace
      const mapping: { [key: string]: string } = {
        'AI Web Agent': 'chat',
        'Word Converter': 'word',
        'PDF Compressor': 'compressor',
        'Media Downloader': 'downloader',
        'PRD Wizard': 'prd-wizard'
      };
      setActiveWorkspace(mapping[selectedServices[0]]);
    }
  };

  const handleCommandPaletteSelect = (workspaceKey: string) => {
    setActiveWorkspace(workspaceKey);
    setShowCommandPalette(false);
  };

  const formatBytes = (bytes: number, decimals = 2) => {
    if (!bytes) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  };

  // PRD Blueprint Markdown Generation
  const generatePRDMarkdown = () => {
    return `# Product Requirement Document (PRD) - ${prdData.name || 'Project Name'}

> **Tagline:** ${prdData.tagline || 'Tagline Proyek'}

---

## 1. Problem & Context
${prdData.problem || 'Penjelasan latar belakang masalah...'}

## 2. Solution Proposal
${prdData.solution || 'Detail solusi perangkat lunak yang diusulkan...'}

## 3. Core Features
${prdData.features.map((f, i) => `${i + 1}. **${f}**`).join('\n')}

## 4. Tech Stack Specification
*   **Platform:** Web Application
*   **Technologies:** ${prdData.techStack}
*   **Database:** SQLite / Relational

---
*Generated using Zays Core PRD Blueprint Wizard.*`;
  };

  const copyPRDToClipboard = () => {
    navigator.clipboard.writeText(generatePRDMarkdown());
    alert('PRD Markdown berhasil disalin ke clipboard!');
  };

  // Filtered command list based on command palette input
  const commandList = [
    { name: 'AI Chat Agent Workspace', desc: 'Buka terminal asisten AI dengan pencarian web', key: 'chat' },
    { name: 'Word to PDF Converter', desc: 'Konversi file DOCX ke PDF lokal dengan cepat', key: 'word' },
    { name: 'PDF Compressor Optimizer', desc: 'Kompresi dan optimasi ukuran file PDF Anda', key: 'compressor' },
    { name: 'HD Media Downloader', desc: 'Unduh video dari sosial media via Cobalt API', key: 'downloader' },
    { name: 'PRD Blueprint Wizard', desc: 'Wizard interaktif pembuat draf dokumen PRD kuliah', key: 'prd-wizard' },
    { name: 'System Diagnostics & Settings', desc: 'Pantau RAM/CPU server dan kunci API Gemini', key: 'diagnostics' }
  ].filter(cmd => cmd.name.toLowerCase().includes(searchQuery.toLowerCase()) || cmd.desc.toLowerCase().includes(searchQuery.toLowerCase()));

  return (
    <div className="relative bg-[#050508] text-neutral-200 font-sans selection:bg-[#EAECE9] selection:text-[#1C2E1E] antialiased overflow-x-hidden flex flex-col lg:block lg:min-h-screen">
      
      {/* BACKGROUND VIDEO & SCRUBBING LAYER (Reference 1 & Reference 2) */}
      <div className="order-last lg:order-none relative lg:absolute lg:inset-0 lg:z-0 overflow-hidden pointer-events-none w-full aspect-square md:aspect-video lg:aspect-auto lg:h-full bg-neutral-950">
        <video
          ref={videoRef}
          src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260406_094145_4a271a6c-3869-4f1c-8aa7-aeb0cb227994.mp4"
          muted={isMuted}
          playsInline
          loop
          autoPlay
          className="w-full h-full object-cover object-center"
        />
      </div>

      {/* BOTTOM BLUR OVERLAY (Reference 2 Blur Overlay, no dark gradient) */}
      <div
        className="fixed inset-0 pointer-events-none z-1"
        style={{
          backdropFilter: 'blur(20px)',
          WebkitBackdropFilter: 'blur(20px)',
          maskImage: 'linear-gradient(to top, black 0%, transparent 45%)',
          WebkitMaskImage: 'linear-gradient(to top, black 0%, transparent 45%)'
        }}
      />

      {/* FOREGROUND CONTENT GRID CONTAINER */}
      <div className="relative z-10 w-full max-w-7xl mx-auto px-6 pt-8 pb-20 lg:pt-10 lg:pb-20 flex flex-col justify-between min-h-screen lg:min-h-0">
        
        {/* MODERN NAVBAR (Reference 2 Layout) */}
        <header className="flex justify-between items-center mb-16 lg:mb-24">
          <div className="flex items-center space-x-3">
            <span className="text-xl font-bold tracking-widest text-white uppercase bg-black/60 px-3 py-1.5 rounded-lg border border-white/10 backdrop-blur-md">
              ZAYS CORE
            </span>
          </div>

          {/* Nav Links for Aesthetic */}
          <nav className="hidden md:flex items-center space-x-6 text-sm font-medium text-neutral-400">
            <span className="hover:text-white transition-colors cursor-pointer">Movies</span>
            <span className="hover:text-white transition-colors cursor-pointer">TV Series</span>
            <span className="hover:text-white transition-colors cursor-pointer">Editor's Pick</span>
            <span className="hover:text-white transition-colors cursor-pointer">Diagnostics</span>
          </nav>

          {/* Right Controls */}
          <div className="flex items-center space-x-3">
            <button
              onClick={() => setShowCommandPalette(true)}
              className="bg-white/5 border border-white/10 flex items-center space-x-2 text-white/80 hover:text-white text-xs px-3.5 py-2 rounded-full cursor-pointer transition-all backdrop-blur-md hover:bg-white/10"
            >
              <Search className="w-3.5 h-3.5" />
              <span className="hidden sm:inline">Workspace ⌘K</span>
            </button>

            <button
              onClick={() => setIsMuted(prev => !prev)}
              className="bg-white/5 border border-white/10 text-white/80 hover:text-white p-2 rounded-full cursor-pointer transition-all backdrop-blur-md hover:bg-white/10"
            >
              {isMuted ? <VolumeX className="w-4 h-4" /> : <Volume2 className="w-4 h-4" />}
            </button>

            <button
              onClick={() => setActiveWorkspace('diagnostics')}
              className="bg-white/5 border border-white/10 text-white/80 hover:text-white p-2 rounded-full cursor-pointer transition-all backdrop-blur-md hover:bg-white/10"
            >
              <User className="w-4 h-4" />
            </button>
          </div>
        </header>

        {/* HERO TITLE HEADLINE & DESCRIPTION */}
        <main className="mb-12 lg:mb-16">
          <div className="max-w-4xl">
            {/* Typewriter Title (Reference 1) */}
            <h1 className="text-[40px] sm:text-6xl lg:text-[76px] font-normal tracking-tight text-white leading-[1.08] mb-6 select-none w-full whitespace-pre-wrap drop-shadow-lg">
              {typewriterText}
              {!typewriterDone && (
                <span className="inline-block w-[2px] h-[1.1em] bg-white align-middle ml-[2px] animate-blink" />
              )}
            </h1>

            {/* Description (Reference 1) */}
            <p className="text-lg md:text-xl text-neutral-300 leading-relaxed font-normal mb-10 max-w-2xl drop-shadow-md">
              Whether you have questions, feedback, or need premium tools, launch our intelligent workspaces to get started immediately.
            </p>

            {/* SERVICE SELECTION PILLS (Reference 1) */}
            <div className="mb-8">
              <h3 className="text-xl font-semibold text-white tracking-tight mb-1">What sort of workspace?</h3>
              <p className="opacity-80 text-neutral-400 text-sm mb-5">Select all that apply</p>
              
              <div className="flex flex-wrap gap-3">
                {servicesList.map(service => {
                  const isSelected = selectedServices.includes(service);
                  return (
                    <button
                      key={service}
                      onClick={() => toggleServiceSelection(service)}
                      className={`flex items-center space-x-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 transform active:scale-95 cursor-pointer ${
                        isSelected
                          ? 'bg-white text-black shadow-lg shadow-white/10'
                          : 'bg-black/40 text-neutral-300 border border-white/10 hover:bg-black/60'
                      }`}
                    >
                      <span>{service}</span>
                      <AnimatePresence>
                        {isSelected && (
                          <motion.span
                            initial={{ scale: 0, opacity: 0 }}
                            animate={{ scale: 1, opacity: 1 }}
                            exit={{ scale: 0, opacity: 0 }}
                            transition={{ type: 'spring', stiffness: 300, damping: 20 }}
                          >
                            <Check className="w-3.5 h-3.5 text-emerald-500 stroke-[3px]" />
                          </motion.span>
                        )}
                      </AnimatePresence>
                    </button>
                  );
                })}
              </div>
            </div>

            {/* CONTINGENT FEEDBACK BANNER (Reference 1) */}
            <div className="min-h-[64px]">
              <AnimatePresence mode="wait">
                {selectedServices.length === 0 ? (
                  <motion.p
                    key="empty"
                    initial={{ opacity: 0 }}
                    animate={{ opacity: 0.5 }}
                    exit={{ opacity: 0 }}
                    className="italic text-xs text-neutral-300 mt-2"
                  >
                    Please click to select workspaces above or press ⌘K to search.
                  </motion.p>
                ) : (
                  <motion.div
                    key="active"
                    initial={{ height: 0, opacity: 0 }}
                    animate={{ height: 'auto', opacity: 1 }}
                    exit={{ height: 0, opacity: 0 }}
                    transition={{ type: 'spring', stiffness: 200, damping: 25 }}
                    className="mt-4 p-4 bg-white/5 border border-white/10 rounded-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 backdrop-blur-md"
                  >
                    <span className="text-sm text-neutral-200">
                      Ready to inquire about: <strong className="text-white">{selectedServices.join(', ')}</strong>
                    </span>
                    <button
                      onClick={openSelectedWorkspaces}
                      className="flex items-center justify-center space-x-1 text-emerald-400 hover:text-emerald-300 uppercase text-xs font-bold tracking-widest cursor-pointer group"
                    >
                      <span>Let's Go</span>
                      <ArrowRight className="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" />
                    </button>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          </div>
        </main>

        {/* 5. Seamless Marquee Logo Scroller Component */}
        <div className="relative w-full overflow-hidden select-none marquee-mask mb-12">
          <div className="animate-marquee flex gap-6 py-4">
            {[...logoList, ...logoList, ...logoList, ...logoList].map((logo, idx) => (
              <div
                key={idx}
                className="group relative h-20 w-36 shrink-0 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:border-white/20 transition-all overflow-hidden cursor-pointer"
              >
                {/* Absolute background color gradient (scale 1.5, opacity 0 -> scale 1, opacity 1) */}
                <div
                  className="absolute inset-0 opacity-0 scale-150 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500 ease-out pointer-events-none z-0"
                  style={{ background: logo.gradient }}
                />

                {/* Logo Image */}
                <div className="relative z-10 flex items-center justify-center transition-all duration-300">
                  <img
                    src={logo.url}
                    alt={logo.name}
                    className="h-6 max-w-[80px] object-contain transition-all duration-300 group-hover:brightness-0 group-hover:invert"
                    onError={(e) => {
                      e.currentTarget.style.display = 'none';
                      const parent = e.currentTarget.parentElement;
                      if (parent) {
                        const textSpan = document.createElement('span');
                        textSpan.className = 'text-[10px] font-bold text-neutral-400 group-hover:text-white uppercase tracking-wider';
                        textSpan.innerText = logo.name;
                        parent.appendChild(textSpan);
                      }
                    }}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* BOTTOM METADATA BAR (Reference 2 Styling) */}
        <footer className="flex flex-col md:flex-row justify-between items-start md:items-center pt-8 border-t border-white/10 gap-4">
          <div className="flex items-center space-x-6 text-xs text-neutral-400">
            <span className="flex items-center space-x-1.5">
              <Play className="w-3 h-3 text-emerald-400 fill-emerald-400" />
              <span className="text-white font-medium">8.7/10 IMDB</span>
            </span>
            <span>•</span>
            <span>132 min</span>
            <span>•</span>
            <span>June, 2026</span>
          </div>

          <div className="flex items-center space-x-2 text-xs text-neutral-400">
            <span>Powered by Gin & SQLite</span>
            <span>•</span>
            <span className="text-emerald-400 font-mono flex items-center space-x-1">
              <span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse inline-block" />
              <span>Server Online</span>
            </span>
          </div>
        </footer>
      </div>

      {/* ====================================================
          COMMAND PALETTE OVERLAY (⌘K / Ctrl+K)
         ==================================================== */}
      <AnimatePresence>
        {showCommandPalette && (
          <div className="fixed inset-0 z-50 flex items-center justify-center p-4">
            {/* Backdrop */}
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setShowCommandPalette(false)}
              className="absolute inset-0 bg-black/70 backdrop-blur-sm"
            />

            {/* Dialog Panel */}
            <motion.div
              initial={{ scale: 0.95, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.95, opacity: 0 }}
              className="relative w-full max-w-lg bg-[#0e0e18]/90 border border-white/15 rounded-3xl overflow-hidden shadow-2xl backdrop-blur-xl z-10"
            >
              <div className="p-4 border-b border-white/10 flex items-center space-x-3">
                <Search className="text-neutral-400 w-5 h-5" />
                <input
                  type="text"
                  placeholder="Ketik nama workspace atau perkakas..."
                  value={searchQuery}
                  onChange={e => setSearchQuery(e.target.value)}
                  className="w-full bg-transparent text-white placeholder-neutral-500 border-none outline-none text-base"
                  autoFocus
                />
                <button
                  onClick={() => setShowCommandPalette(false)}
                  className="text-xs text-neutral-400 bg-white/5 border border-white/10 px-2.5 py-1 rounded-md"
                >
                  ESC
                </button>
              </div>

              <div className="max-h-80 overflow-y-auto p-2">
                {commandList.length === 0 ? (
                  <p className="text-neutral-500 text-sm p-4 text-center">Tidak ada workspace ditemukan.</p>
                ) : (
                  commandList.map(cmd => (
                    <button
                      key={cmd.key}
                      onClick={() => handleCommandPaletteSelect(cmd.key)}
                      className="w-full text-left p-3 rounded-2xl hover:bg-white/5 flex items-center justify-between group transition-colors cursor-pointer"
                    >
                      <div>
                        <h4 className="text-sm font-semibold text-white">{cmd.name}</h4>
                        <p className="text-xs text-neutral-400">{cmd.desc}</p>
                      </div>
                      <ChevronRight className="w-4 h-4 text-neutral-500 group-hover:text-white transition-colors" />
                    </button>
                  ))
                )}
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>

      {/* ====================================================
          ACTIVE WORKSPACE MODAL OVERLAYS
         ==================================================== */}
      <AnimatePresence>
        {activeWorkspace && (
          <div className="fixed inset-0 z-40 flex items-center justify-end p-0 sm:p-4">
            {/* Backdrop */}
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setActiveWorkspace(null)}
              className="absolute inset-0 bg-black/60 backdrop-blur-sm"
            />

            {/* Sidebar-style Workspace Panel */}
            <motion.div
              initial={{ x: '100%' }}
              animate={{ x: 0 }}
              exit={{ x: '100%' }}
              transition={{ type: 'spring', damping: 25, stiffness: 220 }}
              className="relative w-full sm:max-w-2xl h-full sm:h-[90vh] bg-[#0c0c14]/95 border-l sm:border border-white/10 sm:rounded-3xl shadow-2xl flex flex-col backdrop-blur-2xl z-10"
            >
              {/* Drawer Header */}
              <div className="p-5 border-b border-white/10 flex justify-between items-center bg-black/20">
                <div className="flex items-center space-x-3">
                  <Activity className="w-5 h-5 text-emerald-400" />
                  <div>
                    <h2 className="text-lg font-bold text-white capitalize">
                      {activeWorkspace === 'chat' && 'AI Chat Agent'}
                      {activeWorkspace === 'word' && 'Word to PDF Converter'}
                      {activeWorkspace === 'compressor' && 'PDF Compressor'}
                      {activeWorkspace === 'downloader' && 'Cobalt Media Downloader'}
                      {activeWorkspace === 'prd-wizard' && 'PRD Blueprint Wizard'}
                      {activeWorkspace === 'diagnostics' && 'System Settings & Diagnostics'}
                    </h2>
                    <p className="text-xs text-neutral-400">Mainframe OS utility workspace</p>
                  </div>
                </div>
                <button
                  onClick={() => setActiveWorkspace(null)}
                  className="text-xs text-neutral-400 hover:text-white bg-white/5 border border-white/10 px-3 py-1.5 rounded-full cursor-pointer"
                >
                  Tutup [ESC]
                </button>
              </div>

              {/* Drawer Content */}
              <div className="flex-1 overflow-y-auto p-6 text-neutral-200">

                {/* 1. AI CHAT AGENT */}
                {activeWorkspace === 'chat' && (
                  <div className="flex flex-col h-full space-y-4">
                    {/* Chat Messages */}
                    <div className="flex-1 overflow-y-auto space-y-4 p-2 bg-black/30 rounded-2xl border border-white/5 max-h-[380px]">
                      {chatMessages.map((msg, i) => (
                        <div
                          key={i}
                          className={`flex ${msg.sender === 'user' ? 'justify-end' : 'justify-start'}`}
                        >
                          <div
                            className={`max-w-[85%] p-4 rounded-2xl text-sm ${
                              msg.sender === 'user'
                                ? 'bg-white text-black'
                                : 'bg-white/5 border border-white/10 text-white'
                            }`}
                          >
                            <p className="whitespace-pre-wrap leading-relaxed">{msg.text}</p>
                            
                            {/* Sources display */}
                            {msg.sources && msg.sources.length > 0 && (
                              <div className="mt-3 pt-2 border-t border-white/10 text-xs text-neutral-400">
                                <strong>Sumber Online:</strong>
                                {msg.sources.map((src, idx) => (
                                  <a
                                    key={idx}
                                    href={src.url}
                                    target="_blank"
                                    rel="noreferrer"
                                    className="block text-emerald-400 hover:underline mt-1"
                                  >
                                    [{src.source}] {src.title}
                                  </a>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>

                    {/* Step-by-step Execution Log Panel */}
                    {chatLogs.length > 0 && (
                      <div className="p-4 bg-black/50 border border-white/10 rounded-2xl font-mono text-xs text-neutral-300">
                        <div className="flex items-center justify-between mb-2">
                          <span className="text-emerald-400 flex items-center space-x-1.5">
                            <Terminal className="w-3.5 h-3.5" />
                            <span>Execution Steps:</span>
                          </span>
                          {chatLoading && <Loader2 className="w-3.5 h-3.5 animate-spin text-emerald-400" />}
                        </div>
                        <div className="space-y-1 max-h-24 overflow-y-auto">
                          {chatLogs.map((log, i) => (
                            <div key={i} className="flex justify-between">
                              <span className="text-neutral-400">• {log.step}</span>
                              <span className="text-neutral-500">{log.detail}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                    {/* Input Area */}
                    <form onSubmit={handleChatSubmit} className="flex items-center space-x-2">
                      <input
                        type="text"
                        placeholder="Tanyakan asisten AI..."
                        value={chatInput}
                        onChange={e => setChatInput(e.target.value)}
                        disabled={chatLoading}
                        className="flex-1 bg-white/5 border border-white/10 focus:border-white/20 rounded-xl px-4 py-3 outline-none text-white placeholder-neutral-500 text-sm"
                      />
                      <button
                        type="submit"
                        disabled={chatLoading}
                        className="bg-white hover:bg-neutral-200 text-black p-3 rounded-xl cursor-pointer disabled:opacity-50 transition-colors"
                      >
                        <Send className="w-4 h-4" />
                      </button>
                    </form>
                  </div>
                )}

                {/* 2. WORD TO PDF CONVERTER */}
                {activeWorkspace === 'word' && (
                  <div className="space-y-6">
                    <p className="text-sm text-neutral-400">
                      Konversi dokumen Microsoft Word (.docx) secara instan ke PDF tanpa dependensi luar.
                    </p>

                    <div className="border-2 border-dashed border-white/10 hover:border-white/20 rounded-3xl p-8 text-center bg-black/10 transition-colors">
                      <FileText className="w-12 h-12 text-neutral-500 mx-auto mb-4" />
                      <p className="text-sm text-white mb-2">Pilih berkas DOCX Anda</p>
                      <input
                        type="file"
                        accept=".docx"
                        onChange={e => {
                          if (e.target.files && e.target.files[0]) {
                            setWordFile(e.target.files[0]);
                          }
                        }}
                        className="hidden"
                        id="docx-uploader"
                      />
                      <label
                        htmlFor="docx-uploader"
                        className="inline-block bg-white text-black text-xs font-semibold px-4 py-2 rounded-full cursor-pointer hover:bg-neutral-200"
                      >
                        Unggah File
                      </label>
                      {wordFile && <p className="text-xs text-emerald-400 mt-3">Terpilih: {wordFile.name}</p>}
                    </div>

                    {wordFile && (
                      <button
                        onClick={handleWordConversion}
                        disabled={converting}
                        className="w-full bg-white text-black py-3 rounded-xl font-bold hover:bg-neutral-200 cursor-pointer flex items-center justify-center space-x-2"
                      >
                        {converting ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin" />
                            <span>Mengonversi...</span>
                          </>
                        ) : (
                          <>
                            <FileDown className="w-4 h-4" />
                            <span>Konversi ke PDF</span>
                          </>
                        )}
                      </button>
                    )}

                    {convertedPdfUrl && (
                      <div className="p-4 bg-emerald-50/10 border border-emerald-50/25 rounded-2xl flex items-center justify-between">
                        <span className="text-sm text-emerald-400">File PDF berhasil dibuat!</span>
                        <a
                          href={convertedPdfUrl}
                          download={wordFile ? wordFile.name.replace(/\.[^/.]+$/, '') + '.pdf' : 'converted.pdf'}
                          className="bg-emerald-50 text-white text-xs px-3 py-1.5 rounded-lg hover:bg-emerald-600 transition-colors"
                        >
                          Unduh Ulang
                        </a>
                      </div>
                    )}
                  </div>
                )}

                {/* 3. PDF COMPRESSOR */}
                {activeWorkspace === 'compressor' && (
                  <div className="space-y-6">
                    <p className="text-sm text-neutral-400">
                      Perkecil ukuran dokumen PDF secara signifikan menggunakan pustaka optimasi `pdfcpu` lokal.
                    </p>

                    <div className="border-2 border-dashed border-white/10 hover:border-white/20 rounded-3xl p-8 text-center bg-black/10 transition-colors">
                      <FileCode className="w-12 h-12 text-neutral-500 mx-auto mb-4" />
                      <p className="text-sm text-white mb-2">Pilih berkas PDF untuk dikompresi</p>
                      <input
                        type="file"
                        accept=".pdf"
                        onChange={e => {
                          if (e.target.files && e.target.files[0]) {
                            setPdfFile(e.target.files[0]);
                          }
                        }}
                        className="hidden"
                        id="pdf-uploader"
                      />
                      <label
                        htmlFor="pdf-uploader"
                        className="inline-block bg-white text-black text-xs font-semibold px-4 py-2 rounded-full cursor-pointer hover:bg-neutral-200"
                      >
                        Unggah PDF
                      </label>
                      {pdfFile && <p className="text-xs text-emerald-400 mt-3">Terpilih: {pdfFile.name}</p>}
                    </div>

                    {pdfFile && (
                      <button
                        onClick={handleCompressPdf}
                        disabled={compressing}
                        className="w-full bg-white text-black py-3 rounded-xl font-bold hover:bg-neutral-200 cursor-pointer flex items-center justify-center space-x-2"
                      >
                        {compressing ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin" />
                            <span>Mengompresi PDF...</span>
                          </>
                        ) : (
                          <>
                            <Download className="w-4 h-4" />
                            <span>Optimasi PDF</span>
                          </>
                        )}
                      </button>
                    )}

                    {compressionResult && (
                      <div className="p-4 bg-white/5 border border-white/10 rounded-2xl space-y-3">
                        <h4 className="text-sm font-bold text-white">Hasil Kompresi:</h4>
                        <div className="grid grid-cols-2 gap-4 text-xs">
                          <div>
                            <span className="text-neutral-400 block">Ukuran Awal:</span>
                            <span className="text-white font-medium">{formatBytes(compressionResult.originalSize)}</span>
                          </div>
                          <div>
                            <span className="text-neutral-400 block">Ukuran Baru:</span>
                            <span className="text-emerald-400 font-medium">
                              {formatBytes(compressionResult.compressedSize)} ({Math.round((1 - compressionResult.compressedSize / compressionResult.originalSize) * 100)}% Hemat)
                            </span>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {/* 4. COBALT MEDIA DOWNLOADER */}
                {activeWorkspace === 'downloader' && (
                  <div className="space-y-6">
                    <p className="text-sm text-neutral-400">
                      Unduh video atau audio dari YouTube, TikTok, Twitter, Instagram dengan aman melalui Cobalt API.
                    </p>

                    <form onSubmit={handleMediaDownload} className="space-y-4">
                      <div>
                        <label className="block text-xs font-semibold text-neutral-400 mb-2">Tautan Video/Audio</label>
                        <input
                          type="url"
                          placeholder="https://www.youtube.com/watch?v=..."
                          value={mediaUrl}
                          onChange={e => setMediaUrl(e.target.value)}
                          required
                          className="w-full bg-white/5 border border-white/10 focus:border-white/20 rounded-xl px-4 py-3 outline-none text-white text-sm"
                        />
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-xs font-semibold text-neutral-400 mb-2">Format</label>
                          <select
                            value={mediaFormat}
                            onChange={e => setMediaFormat(e.target.value)}
                            className="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 outline-none text-white text-sm"
                          >
                            <option value="mp4" className="bg-[#0e0e18]">MP4 (Video)</option>
                            <option value="mp3" className="bg-[#0e0e18]">MP3 (Audio)</option>
                          </select>
                        </div>
                        <div>
                          <label className="block text-xs font-semibold text-neutral-400 mb-2">Kualitas</label>
                          <select
                            value={mediaQuality}
                            onChange={e => setMediaQuality(e.target.value)}
                            className="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 outline-none text-white text-sm"
                          >
                            <option value="1080" className="bg-[#0e0e18]">1080p (Full HD)</option>
                            <option value="720" className="bg-[#0e0e18]">720p (HD)</option>
                            <option value="480" className="bg-[#0e0e18]">480p (SD)</option>
                          </select>
                        </div>
                      </div>

                      <button
                        type="submit"
                        disabled={downloadingMedia}
                        className="w-full bg-white text-black py-3 rounded-xl font-bold hover:bg-neutral-200 cursor-pointer flex items-center justify-center space-x-2"
                      >
                        {downloadingMedia ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin" />
                            <span>Mengekstrak Tautan HD...</span>
                          </>
                        ) : (
                          <>
                            <Video className="w-4 h-4" />
                            <span>Dapatkan Link Download</span>
                          </>
                        )}
                      </button>
                    </form>

                    {downloaderResult && (
                      <div className="p-4 bg-white/5 border border-white/10 rounded-2xl space-y-3">
                        <div className="flex justify-between items-start">
                          <div>
                            <h4 className="text-sm font-bold text-white">{downloaderResult.title}</h4>
                            <p className="text-xs text-neutral-400 mt-1">Status: {downloaderResult.status}</p>
                          </div>
                          <a
                            href={downloaderResult.downloadUrl}
                            target="_blank"
                            rel="noreferrer"
                            className="bg-emerald-50 text-white text-xs px-3 py-2 rounded-lg hover:bg-emerald-600 transition-colors flex items-center space-x-1"
                          >
                            <Download className="w-3 h-3" />
                            <span>Unduh Sekarang</span>
                          </a>
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {/* 5. PRD BLUEPRINT WIZARD */}
                {activeWorkspace === 'prd-wizard' && (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6 h-full">
                    {/* Wizard Steps */}
                    <div className="space-y-4">
                      <div className="flex items-center space-x-2 text-xs font-semibold text-neutral-400">
                        <span>Langkah {wizardStep} dari 3</span>
                      </div>

                      {wizardStep === 1 && (
                        <div className="space-y-3">
                          <div>
                            <label className="block text-xs font-semibold text-neutral-400 mb-1">Nama Aplikasi/Produk</label>
                            <input
                              type="text"
                              value={prdData.name}
                              onChange={e => setPrdData({ ...prdData, name: e.target.value })}
                              placeholder="Contoh: Sakha Art App"
                              className="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 outline-none text-white text-sm"
                            />
                          </div>
                          <div>
                            <label className="block text-xs font-semibold text-neutral-400 mb-1">Tagline</label>
                            <input
                              type="text"
                              value={prdData.tagline}
                              onChange={e => setPrdData({ ...prdData, tagline: e.target.value })}
                              placeholder="Slogan produk Anda..."
                              className="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 outline-none text-white text-sm"
                            />
                          </div>
                        </div>
                      )}

                      {wizardStep === 2 && (
                        <div className="space-y-3">
                          <div>
                            <label className="block text-xs font-semibold text-neutral-400 mb-1">Pernyataan Masalah</label>
                            <textarea
                              value={prdData.problem}
                              onChange={e => setPrdData({ ...prdData, problem: e.target.value })}
                              placeholder="Masalah apa yang ingin diselesaikan?"
                              className="w-full h-20 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 outline-none text-white text-sm resize-none"
                            />
                          </div>
                          <div>
                            <label className="block text-xs font-semibold text-neutral-400 mb-1">Solusi yang Diusulkan</label>
                            <textarea
                              value={prdData.solution}
                              onChange={e => setPrdData({ ...prdData, solution: e.target.value })}
                              placeholder="Bagaimana aplikasi ini menyelesaikannya?"
                              className="w-full h-20 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 outline-none text-white text-sm resize-none"
                            />
                          </div>
                        </div>
                      )}

                      {wizardStep === 3 && (
                        <div className="space-y-3">
                          <div>
                            <label className="block text-xs font-semibold text-neutral-400 mb-2">Daftar Fitur Utama</label>
                            <div className="space-y-2">
                              {prdData.features.map((feat, idx) => (
                                <div key={idx} className="flex items-center justify-between bg-white/5 px-3 py-2 rounded-xl">
                                  <span className="text-xs text-white">{feat}</span>
                                  <button
                                    onClick={() => setPrdData({
                                      ...prdData,
                                      features: prdData.features.filter((_, i) => i !== idx)
                                    })}
                                    className="text-red-400 hover:text-red-300"
                                  >
                                    <Trash className="w-3.5 h-3.5" />
                                  </button>
                                </div>
                              ))}
                            </div>
                            <div className="flex items-center space-x-2 mt-2">
                              <input
                                type="text"
                                placeholder="Tambahkan fitur baru..."
                                value={newFeature}
                                onChange={e => setNewFeature(e.target.value)}
                                className="flex-1 bg-white/5 border border-white/10 rounded-xl px-3 py-2 outline-none text-white text-xs"
                              />
                              <button
                                type="button"
                                onClick={() => {
                                  if (newFeature.trim()) {
                                    setPrdData({ ...prdData, features: [...prdData.features, newFeature.trim()] });
                                    setNewFeature('');
                                  }
                                }}
                                className="bg-white text-black p-2 rounded-xl"
                              >
                                <Plus className="w-3.5 h-3.5" />
                              </button>
                            </div>
                          </div>
                        </div>
                      )}

                      <div className="flex justify-between pt-4">
                        <button
                          disabled={wizardStep === 1}
                          onClick={() => setWizardStep(prev => prev - 1)}
                          className="bg-white/5 hover:bg-white/10 text-white px-4 py-2 rounded-xl text-xs disabled:opacity-30 cursor-pointer"
                        >
                          Kembali
                        </button>
                        {wizardStep < 3 ? (
                          <button
                            onClick={() => setWizardStep(prev => prev + 1)}
                            className="bg-white text-black px-4 py-2 rounded-xl text-xs cursor-pointer"
                          >
                            Selanjutnya
                          </button>
                        ) : (
                          <button
                            onClick={copyPRDToClipboard}
                            className="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-xl text-xs font-semibold cursor-pointer"
                          >
                            Salin Markdown
                          </button>
                        )}
                      </div>
                    </div>

                    {/* PRD Preview */}
                    <div className="p-4 bg-black/40 border border-white/5 rounded-2xl overflow-y-auto max-h-[300px] text-xs font-mono whitespace-pre-wrap">
                      {generatePRDMarkdown()}
                    </div>
                  </div>
                )}

                {/* 6. DIAGNOSTICS & SETTINGS */}
                {activeWorkspace === 'diagnostics' && (
                  <div className="space-y-6">
                    <p className="text-sm text-neutral-400">
                      Pantau parameter kinerja server backend secara langsung dan kelola kredensial API.
                    </p>

                    {/* Real-time Load Indicators */}
                    <div className="grid grid-cols-2 gap-4">
                      <div className="p-4 bg-white/5 border border-white/10 rounded-2xl">
                        <span className="text-neutral-400 text-xs block mb-1">CPU Usage</span>
                        <div className="flex items-center space-x-2">
                          <Cpu className="w-4 h-4 text-emerald-400" />
                          <span className="text-lg font-bold text-white">{diagnostics?.cpu || '0.0%'}</span>
                        </div>
                      </div>
                      <div className="p-4 bg-white/5 border border-white/10 rounded-2xl">
                        <span className="text-neutral-400 text-xs block mb-1">RAM Usage</span>
                        <div className="flex items-center space-x-2">
                          <Activity className="w-4 h-4 text-sky-400" />
                          <span className="text-lg font-bold text-white">{diagnostics?.ram || '0.0%'}</span>
                        </div>
                      </div>
                    </div>

                    {/* Latency Tester */}
                    <div className="p-4 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-between">
                      <div>
                        <span className="text-neutral-400 text-xs block">Connection Latency</span>
                        <span className="text-sm font-semibold text-white">
                          {pingLatency !== null ? `${pingLatency} ms` : 'Belum diuji'}
                        </span>
                      </div>
                      <button
                        onClick={handlePing}
                        className="bg-white text-black text-xs px-3 py-2 rounded-xl hover:bg-neutral-200"
                      >
                        Ping Server
                      </button>
                    </div>

                    {/* API Settings Manager */}
                    <div className="p-4 bg-white/5 border border-white/10 rounded-3xl space-y-4">
                      <h3 className="text-sm font-bold text-white flex items-center space-x-2">
                        <Lock className="w-4 h-4 text-amber-400" />
                        <span>Kredensial API Studio</span>
                      </h3>
                      <div>
                        <label className="block text-xs text-neutral-400 mb-2">Google Gemini API Key</label>
                        <input
                          type="password"
                          value={geminiKey}
                          onChange={e => setGeminiKey(e.target.value)}
                          placeholder="AI Studio API Key (AIzaSy...)"
                          className="w-full bg-white/5 border border-white/10 focus:border-white/20 rounded-xl px-4 py-3 outline-none text-white text-sm"
                        />
                      </div>
                      <button
                        onClick={saveSettings}
                        disabled={settingsLoading}
                        className="w-full bg-white text-black py-2.5 rounded-xl text-xs font-bold hover:bg-neutral-200 cursor-pointer"
                      >
                        {settingsLoading ? 'Menyimpan...' : 'Simpan Kunci API'}
                      </button>
                    </div>
                  </div>
                )}
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
}
